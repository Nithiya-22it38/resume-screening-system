# ─── Anthropic API (OPTIONAL) ────────────────────────────────────────────────
# Leave blank or as-is to run in DEMO MODE (no API key needed, realistic mock data)
# Get a real key at https://console.anthropic.com to enable real AI screening
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── JWT (change this in production!) ────────────────────────────────────────
JWT_SECRET=hireiq-dev-secret-change-in-production
JWT_EXPIRES_IN=7d

# ─── File Upload ─────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=./uploads

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ─── CORS ────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
